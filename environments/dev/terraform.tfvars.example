# =============================================================================
# AI Talent Camp Infrastructure - Example Configuration
# =============================================================================
# Copy this file to terraform.tfvars and fill in your values
# DO NOT commit terraform.tfvars to git!
# =============================================================================

# =============================================================================
# Cloud.ru Evolution Configuration (REQUIRED)
# =============================================================================

# Project ID from console.cloud.ru (URL of your project)
project_id = "xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"

# Service account API key (generate in Cloud.ru console -> Service accounts -> Keys)
auth_key_id = ""
auth_secret = ""

# =============================================================================
# Network Configuration
# =============================================================================

subnet_cidr = "10.0.1.0/24"

# =============================================================================
# Project Configuration
# =============================================================================

domain = "south.aitalenthub.ru"

# =============================================================================
# Edge VM Configuration
# =============================================================================

edge_cores     = 2
edge_memory    = 4    # GB
edge_disk_size = 20   # GB

# SSH public key for admin access to jump host (REQUIRED)
jump_user       = "jump"
jump_public_key = "ssh-ed25519 AAAA... admin@example.com"

# =============================================================================
# Team VM Configuration
# =============================================================================

team_cores     = 4
team_memory    = 8    # GB
team_disk_size = 65   # GB

# Team definitions - start empty, add incrementally
# Each team needs: user (VM username), public_keys (extra SSH keys), ip (static IP in subnet)
teams = {}

# Example:
# teams = {
#   "team01"    = { user = "team01",    public_keys = [], ip = "10.0.1.11" }
#   "dashboard" = { user = "dashboard", public_keys = [], ip = "10.0.1.100" }
#   "shared"    = { user = "shared",    public_keys = [], ip = "10.0.1.101" }
# }
